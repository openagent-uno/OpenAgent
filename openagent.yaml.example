name: my-assistant

system_prompt: |
  You are a helpful assistant.

model:
  provider: claude-api           # claude-api | claude-cli | zhipu
  model_id: claude-sonnet-4-6
  api_key: ${ANTHROPIC_API_KEY}

# Default MCPs are always loaded automatically:
#   - filesystem (read/write/list/search files)
#   - editor (surgical edit, grep, glob)
#   - web-search (web search + single page fetch, no API key needed)
#   - shell (cross-platform shell command execution)
#   - computer-use (screenshot, mouse, keyboard control)
#
# To disable all defaults:
#   mcp_defaults: false
#
# To disable specific defaults:
#   mcp_disable: ["computer-use", "web-search"]

# User MCPs are merged on top of defaults:
mcp:
  # Remote MCP server (SSE transport)
  # - name: web-search
  #   url: "http://localhost:8080/sse"

  # Override the default filesystem root:
  # - name: filesystem
  #   command: ["npx", "-y", "@modelcontextprotocol/server-filesystem"]
  #   args: ["/Users/me/data"]

memory:
  db_path: "./openagent.db"
  auto_extract: true

channels:
  telegram:
    token: ${TELEGRAM_BOT_TOKEN}
  discord:
    token: ${DISCORD_BOT_TOKEN}
  whatsapp:
    green_api_id: ${GREEN_API_ID}
    green_api_token: ${GREEN_API_TOKEN}
