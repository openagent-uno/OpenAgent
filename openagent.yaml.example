name: my-assistant

system_prompt: |
  You are a helpful assistant.

model:
  provider: claude-api           # claude-api | claude-cli | zhipu
  model_id: claude-sonnet-4-6
  api_key: ${ANTHROPIC_API_KEY}

# Default MCPs are always loaded automatically:
#   - filesystem (read/write/list/search files)
#   - editor (surgical edit, grep, glob)
#   - web-search (web search + single page fetch, no API key needed)
#   - shell (cross-platform shell command execution)
#   - computer-control (screenshot, mouse, keyboard control)
#   - chrome-devtools (browser automation, DOM, performance)
#
# To disable all defaults:
#   mcp_defaults: false
#
# To disable specific defaults:
#   mcp_disable: ["computer-control", "chrome-devtools"]

# User MCPs are merged on top of defaults:
mcp:
  # Proactive messaging (requires channel tokens):
  # - builtin: messaging
  #   env:
  #     TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
  #     DISCORD_BOT_TOKEN: ${DISCORD_BOT_TOKEN}
  #     GREEN_API_ID: ${GREEN_API_ID}
  #     GREEN_API_TOKEN: ${GREEN_API_TOKEN}

  # Remote MCP server:
  # - name: web-search
  #   url: "http://localhost:8080/sse"

memory:
  db_path: "./openagent.db"
  knowledge_dir: "./memories"    # Obsidian-compatible .md files (FTS5 indexed)
  auto_extract: true

# Scheduled tasks (cron-based, stored in DB, survive reboots)
scheduler:
  enabled: true
  tasks: []
  # Example:
  # - name: daily-report
  #   cron: "0 9 * * *"
  #   prompt: "Generate and send the daily status report"

# Dream Mode — nightly maintenance routine (built-in scheduled task)
# Cleans temp files, consolidates memory, checks system health.
dream_mode:
  enabled: true
  time: "3:00"           # Shorthand: runs daily at this time (HH:MM)
  # cron: "0 3 * * *"    # Or use a full cron expression instead of 'time'

channels:
  telegram:
    token: ${TELEGRAM_BOT_TOKEN}
  discord:
    token: ${DISCORD_BOT_TOKEN}
  whatsapp:
    green_api_id: ${GREEN_API_ID}
    green_api_token: ${GREEN_API_TOKEN}
